# ============================================================================
# .env.example  ·  Copiar a .env y completar (el .env real NO se versiona).
# Credenciales y endpoints de los 3 SGBD heterogeneos.
# ============================================================================

# ── Oracle 19c (nativo, puerto 1523) ──────────────────────────
ORA_HOST=oracle.lab.local
ORA_PORT=1523
ORA_SERVICE=orclpdb.lab.local
ORA_APP_USER=logistica
ORA_APP_PWD=Logist1ca#2026
ORA_SYNC_USER=sync_reader_ora
ORA_SYNC_PWD=SyncRead#2026

# ── MariaDB 11 (Docker, puerto 3307) ──────────────────────────
MARIA_HOST=192.168.152.191
MARIA_PORT=3307
MARIA_DB=inventarios
MARIA_DBA_USER=dba_mariadb
MARIA_DBA_PWD=MariaProj#2026
MARIA_SYNC_USER=sync_reader
MARIA_SYNC_PWD=SyncRead#2026

# ── SQL Server 2022 (Docker, puerto 1434) ─────────────────────
MSSQL_HOST=192.168.152.191
MSSQL_PORT=1434
MSSQL_DB=reportes
MSSQL_SYNC_USER=sync_writer
MSSQL_SYNC_PWD=SyncWrite#2026
MSSQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
